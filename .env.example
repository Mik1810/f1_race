# This file documents the environment variables used by docker-compose.yml.
#
# RECOMMENDED: run  bash docker/setup.sh  to auto-detect SICStus and generate
# .env automatically.
#
# MANUAL: copy this file to .env and edit SICSTUS_PATH.
#
# SICSTUS_PATH — full path to the SICStus Prolog 4.6.0 install on the HOST.
# The directory is mounted read-only inside the MAS container.
# The licence file stays on the host — no copying needed.
#
# Common values:
#   /usr/local/sicstus4.6.0        (standard Linux / WSL install)
#   /opt/sicstus4.6.0              (alternate prefix)
#
# If sicstus is in your PATH you can auto-fill with:
#   echo "SICSTUS_PATH=$(dirname $(dirname $(which sicstus)))" > .env
#
SICSTUS_PATH=/usr/local/sicstus4.6.0
